rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // If they have any other collections like notifications, etc. 
    // They might be needed here. E.g. 'notifications' 
    match /notifications/{notificationId} {
      allow read: if request.auth != null; // Everyone can read for now
      allow write: if request.auth != null; // Anyone logged in can write for now
    }
  }
}
